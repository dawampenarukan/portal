# ── Mode 1: Database lokal (default) ──
DATABASE_URL="postgresql://postgres:PasswordBaru123@localhost:5432/sppg_penarukan2?schema=public"
NEXTAUTH_SECRET="change-me-to-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# ── Mode 2: Dev pakai data PRODUCTION (sama dengan Vercel) ──
# Jalankan: npm run env:pull
#   → membuat .env.local dengan DATABASE_URL dari Vercel
#   → NEXTAUTH_URL tetap http://localhost:3000
# Kembali ke DB lokal: npm run env:local
#
# Manual: salin .env.local.example → .env.local, isi DATABASE_URL dari Vercel dashboard

# PENTING — dev vs npm run start:
#   npm run dev   → .env + .env.local
#   npm run start → .env + .env.local + .env.production
# Jangan buat .env.production lokal kecuali sengaja ingin URL berbeda.

# Admin default (setelah db:seed atau db:ensure-admin):
# Email: admin@sppgpenarukan2.id
# Password: admin123

