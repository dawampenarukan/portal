# Salin ke `.env` untuk development lokal:
#   cp .env.example .env
#
# Pola dua database (disarankan):
#   .env              → Postgres lokal (npm run dev)
#   Vercel dashboard  → Neon production (deploy)
#   .env.neon         → opsional, HANYA untuk `npm run db:deploy` ke Neon (jangan commit)

# ── Lokal (wajib) ──
DATABASE_URL="postgresql://postgres:PasswordBaru123@localhost:5432/sppg_penarukan2?schema=public"
DIRECT_URL="postgresql://postgres:PasswordBaru123@localhost:5432/sppg_penarukan2?schema=public"
NEXTAUTH_SECRET="change-me-to-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# Admin setelah seed: admin@sppgpenarukan2.id / admin123

# ── Sync Menu ← Inventory (opsional lokal) ──
# INVENTORY_APP_URL="http://localhost:3001"
# INVENTORY_API_KEY="sk_..."
# INVENTORY_KITCHEN_ID=""

# ── Upload (opsional lokal; di Vercel pakai Blob Store) ──
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# ── Production (isi di Vercel Environment Variables, BUKAN di .env lokal) ──
# DATABASE_URL  = Neon pooled  (...-pooler...?sslmode=require&connection_limit=1)
# DIRECT_URL    = Neon direct  (tanpa -pooler)
# NEXTAUTH_URL  = https://sppgpenarukan2.vercel.app
# NEXTAUTH_SECRET, BLOB_READ_WRITE_TOKEN, INVENTORY_APP_URL, INVENTORY_API_KEY
#
# Migrate Neon sekali jalan (buat file .env.neon dari URL Neon, lalu):
#   set -a && source .env.neon && set +a && npm run db:deploy
