# ── Mode 1: Database lokal (default) ──
# Lokal: DATABASE_URL dan DIRECT_URL boleh sama (Postgres di WSL/Windows).
DATABASE_URL="postgresql://postgres:PasswordBaru123@localhost:5432/sppg_penarukan2?schema=public"
DIRECT_URL="postgresql://postgres:PasswordBaru123@localhost:5432/sppg_penarukan2?schema=public"
NEXTAUTH_SECRET="change-me-to-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# ── Mode 2: Dev pakai data PRODUCTION (sama dengan Vercel) ──
# Jalankan: npm run env:pull
#   → membuat .env.local dengan DATABASE_URL (+ DIRECT_URL jika ada di Vercel)
#   → NEXTAUTH_URL tetap http://localhost:3000
# Kembali ke DB lokal: npm run env:local
#
# Manual: salin .env.local.example → .env.local, isi URL dari Vercel dashboard

# PENTING — dev vs npm run start:
#   npm run dev   → .env + .env.local
#   npm run start → .env + .env.local + .env.production
# Jangan buat .env.production lokal kecuali sengaja ingin URL berbeda.

# Admin default (setelah db:seed atau db:ensure-admin):
# Email: admin@sppgpenarukan2.id
# Password: admin123

# --- Sync Menu Minggu Ini dari Inventory (Food Production) ---
# Inventory harus expose GET /api/fp-public/plans + API key scope food-production:read
# INVENTORY_APP_URL="http://localhost:3001"
# INVENTORY_API_KEY="sk_..."
# Opsional filter dapur:
# INVENTORY_KITCHEN_ID=""


# --- Vercel (Production) — WAJIB ganti semua localhost! ---
# DATABASE_URL = Neon **pooled** (ada "-pooler" di host), contoh:
#   postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&connection_limit=1
# DIRECT_URL = Neon **direct** (tanpa "-pooler"), untuk prisma db push / migrate:
#   postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
# NEXTAUTH_URL="https://sppgpenarukan2.vercel.app"
# NEXTAUTH_SECRET="random-secret-panjang"
# BLOB_READ_WRITE_TOKEN="vercel_blob_..."  # otomatis setelah buat Blob Store di Vercel Storage
