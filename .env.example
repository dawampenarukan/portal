# Lokal (WSL): PostgreSQL di localhost
# Setelah clone, jalankan: npm run db:setup
DATABASE_URL="postgresql://postgres:PasswordBaru123@localhost:5432/sppg_penarukan2?schema=public"
NEXTAUTH_SECRET="change-me-to-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# Admin default (setelah db:seed atau db:ensure-admin):
# Email: admin@sppgpenarukan2.id
# Password: admin123

# --- Vercel (Production) ---
# JANGAN pakai localhost! Gunakan PostgreSQL cloud (Neon, Supabase, Vercel Postgres, dll).
# Contoh Neon:
# DATABASE_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"
# NEXTAUTH_URL="https://your-app.vercel.app"
# Set ketiga variabel di Vercel → Settings → Environment Variables (Production + Preview)
