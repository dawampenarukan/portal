generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  EDITOR
  AUTHOR
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum FeedbackStatus {
  NEW
  IN_PROGRESS
  RESOLVED
  REJECTED
}

enum PublicationType {
  SURVEY_RESULT
  PERFORMANCE_REPORT
  INFOGRAPHIC
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  role         UserRole  @default(AUTHOR)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  articles     Article[]
  comments     Comment[]
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  articles  Article[]
  createdAt DateTime  @default(now())
}

model Article {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  excerpt     String?
  content     String        @db.Text
  coverImage  String?
  status      ArticleStatus @default(DRAFT)
  isPopular   Boolean       @default(false)
  isHighlight Boolean       @default(false)
  publishedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  authorId    String
  author      User          @relation(fields: [authorId], references: [id])
  categoryId  String
  category    Category      @relation(fields: [categoryId], references: [id])
  comments    Comment[]

  @@index([status, publishedAt])
}

model Comment {
  id          String    @id @default(cuid())
  content     String    @db.Text
  guestName   String?
  isApproved  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  articleId   String
  article     Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  authorId    String?
  author      User?     @relation(fields: [authorId], references: [id])
  parentId    String?
  parent      Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies     Comment[] @relation("CommentReplies")

  @@index([articleId, isApproved])
}

model Event {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?  @db.Text
  location    String
  startAt     DateTime
  endAt       DateTime?
  coverImage  String?
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Publication {
  id          String          @id @default(cuid())
  title       String
  slug        String          @unique
  summary     String?
  content     String          @db.Text
  type        PublicationType
  period      String
  chartData   Json?
  isPublished Boolean         @default(false)
  publishedAt DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model Feedback {
  id          String         @id @default(cuid())
  name        String
  email       String?
  phone       String?
  title       String
  description String         @db.Text
  category    String?
  images      String[]
  status      FeedbackStatus @default(NEW)
  adminNotes  String?        @db.Text
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([status, createdAt])
}

model Survey {
  id               String           @id @default(cuid())
  title            String
  description      String?
  respondentTarget Int              @default(100)
  isActive         Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  questions        SurveyQuestion[]
  responses        SurveyResponse[]
}

model SurveyQuestion {
  id       String       @id @default(cuid())
  surveyId String
  survey   Survey       @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  question String
  type     String
  options  Json?
  order    Int          @default(0)
  answers  SurveyAnswer[]
}

model SurveyResponse {
  id          String         @id @default(cuid())
  surveyId    String
  survey      Survey         @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  respondentName String?
  createdAt   DateTime       @default(now())
  answers     SurveyAnswer[]
}

model SurveyAnswer {
  id         String         @id @default(cuid())
  responseId String
  response   SurveyResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  questionId String
  question   SurveyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  value      String
}

enum MenuCategoryType {
  PORSI_KECIL
  PORSI_BESAR
  IBU_HAMIL
  BALITA
}

enum OrganolepticPlaceType {
  SEKOLAH
  POSYANDU
  LAINNYA
}

enum OrganolepticTiming {
  SAAT_TIBA
  SEBELUM_DIKONSUMSI
}

enum OrganolepticSafety {
  AMAN
  TIDAK_AMAN
}

model MenuItem {
  id          String           @id @default(cuid())
  name        String
  description String?
  emoji       String?
  category    MenuCategoryType
  votes       Int              @default(0)
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  requests    MenuRequest[]
  itemVotes   MenuItemVote[]

  @@index([category, votes])
}

model MenuItemVote {
  id         String   @id @default(cuid())
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  voterKey   String
  createdAt  DateTime @default(now())

  @@unique([menuItemId, voterKey])
  @@index([voterKey])
}

model MenuRequest {
  id           String           @id @default(cuid())
  requesterName String
  category     MenuCategoryType
  menuName     String
  reason       String?          @db.Text
  status       FeedbackStatus   @default(NEW)
  menuItemId   String?
  menuItem     MenuItem?        @relation(fields: [menuItemId], references: [id])
  createdAt    DateTime         @default(now())

  @@index([category, status])
}

model WeeklyMenuEntry {
  id        String           @id @default(cuid())
  category  MenuCategoryType
  dayLabel  String
  menuText  String
  emoji     String?          @default("🍽️")
  sortOrder Int              @default(0)
  isActive  Boolean          @default(true)
  updatedAt DateTime         @updatedAt

  @@index([category, sortOrder])
}

model OrganolepticChecklist {
  id             String                @id @default(cuid())
  inspectorName  String
  placeType      OrganolepticPlaceType
  placeName      String
  inspectionDate DateTime              @db.Date
  inspectionTime String
  timing         OrganolepticTiming
  criticism      String?               @db.Text
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  items          OrganolepticItem[]

  @@index([inspectionDate])
  @@index([placeName, inspectionDate])
}

model OrganolepticItem {
  id           String               @id @default(cuid())
  checklistId  String
  checklist    OrganolepticChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  sortOrder    Int                  @default(0)
  foodName     String
  tasteScore   Int
  colorScore   Int
  aromaScore   Int
  textureScore Int
  safety       OrganolepticSafety
  notes        String?

  @@index([checklistId, sortOrder])
}
